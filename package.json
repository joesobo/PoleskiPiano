{
  "name": "poleski-piano",
  "productName": "PoleskiPiano",
  "version": "0.0.0",
  "description": "Native MIDI piano practice app for a 37-key Launchkey-style keyboard.",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "node scripts/run-electron-vite.mjs preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@tonejs/piano": "0.2.1",
    "fast-xml-parser": "^5.7.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tone": "14.9.17",
    "webmidi": "2.5.3"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "41.3.0",
    "electron-vite": "5.0.0",
    "typescript": "latest",
    "vite": "7.3.2",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
